# SD Digitals Scheduler API — Environment Variables
# Copy this to .env and fill in your values

NODE_ENV=development
PORT=3001

# PostgreSQL Connection
DB_HOST=localhost
DB_PORT=5432
DB_NAME=sd_digitals_scheduler
DB_USER=postgres
DB_PASSWORD=your_password_here
DB_SSL=false

# CORS
FRONTEND_URL=http://localhost:5173

# Security (JWT)
# JWT_SECRET is required in production (refuses to boot without it)
JWT_SECRET=your_jwt_secret_here

# Seed Configuration (Main Admin)
# Required for DB migrations/setup in production
MAIN_ADMIN_EMAIL=admin@sddigitals.com
MAIN_ADMIN_PASSWORD=your_secure_password_here

# Email (SMTP Notifications)
# Configure these to send email confirmations and alerts
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=your_email@gmail.com
SMTP_PASSWORD=your_smtp_app_password
SMTP_FROM=SD Digitals <no-reply@sddigitals.in>

# Razorpay Integration (Test Mode)
RAZORPAY_KEY_ID=your_razorpay_key_id_here
RAZORPAY_KEY_SECRET=your_razorpay_key_secret_here
RAZORPAY_WEBHOOK_SECRET=your_razorpay_webhook_secret_here
