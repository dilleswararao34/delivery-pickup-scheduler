  "version": "1.0.0",
  "description": "SD Digitals Delivery & Pickup Scheduler — Express API",
  "main": "server.js",
  "scripts": {
    "start": "node server.js",
    "dev": "nodemon server.js",
    "migrate": "node src/db/migrate.js",
    "seed": "node src/db/seed.js",
